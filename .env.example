# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in the values. .env.local is git-ignored.
# ---------------------------------------------------------------------------

# Coach signup gate. Anyone signing up as a coach must enter this password.
# Set the real value in .env.local (which is git-ignored) — never commit it here.
COACH_SIGNUP_PASSWORD=change-me

# --- Firebase client config (browser-safe; from Firebase console > Project settings > Your apps) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-only; from a service account JSON key) ---
# Generate at: Firebase console > Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private_key value, keeping the \n escape sequences, wrapped in double quotes:
FIREBASE_PRIVATE_KEY=""

# --- Anthropic (Claude) for the Insight tab ---
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6 in code (cheaper/fast).
# Use claude-opus-4-8 for the most thorough analysis.
ANTHROPIC_MODEL=claude-sonnet-4-6
