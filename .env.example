# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in the values. .env.local is git-ignored.
# ---------------------------------------------------------------------------

# Coach signup gate. Anyone signing up as a coach must enter this password.
# Set the real value in .env.local (which is git-ignored) — never commit it here.
COACH_SIGNUP_PASSWORD=change-me

# --- Firebase client config (browser-safe; from Firebase console > Project settings > Your apps) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server-only; from a service account JSON key) ---
# Generate at: Firebase console > Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private_key value, keeping the \n escape sequences, wrapped in double quotes:
FIREBASE_PRIVATE_KEY=""

# --- USDA FoodData Central (food-database search) ---
# Optional but recommended: enables generic whole-food results in food search.
# Free key (instant) at https://fdc.nal.usda.gov/api-key-signup.html
# Open Food Facts (branded foods + barcode scan) works without any key.
USDA_FDC_API_KEY=

# --- Anthropic (Claude) for the Insight tab ---
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6 in code (cheaper/fast).
# Use claude-opus-4-8 for the most thorough analysis.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Reminder cron (daily food / weekly weigh-in nudges via Resend) ---
# Secret that guards /api/cron/reminders. Vercel automatically sends this as a
# Bearer token on scheduled cron invocations. Generate any long random string.
CRON_SECRET=

# --- Stripe billing (TEST mode first) ---
# Secret key from Stripe Dashboard > Developers > API keys (use sk_test_ first).
STRIPE_SECRET_KEY=
# Signing secret for the /api/stripe/webhook endpoint (whsec_...). From
# Stripe Dashboard > Developers > Webhooks after adding the endpoint, or from
# `stripe listen` during local testing.
STRIPE_WEBHOOK_SECRET=
# Price IDs — run `STRIPE_SECRET_KEY=sk_test_... node scripts/provision-stripe.mjs`
# and paste the printed values here (and into Vercel). These are not secret.
NEXT_PUBLIC_STRIPE_PRICE_3MO_UPFRONT=
NEXT_PUBLIC_STRIPE_PRICE_3MO_INSTALLMENT=
NEXT_PUBLIC_STRIPE_PRICE_6MO_UPFRONT=
NEXT_PUBLIC_STRIPE_PRICE_6MO_INSTALLMENT=
NEXT_PUBLIC_STRIPE_PRICE_1YR_UPFRONT=
NEXT_PUBLIC_STRIPE_PRICE_1YR_INSTALLMENT=
